{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniPlan",
  "version": "0.1.0",
  "identifier": "uk.co.ldenergy.omniplan",
  "build": {
    "beforeDevCommand": "pnpm --filter @floorplan/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @floorplan/web build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OmniPlan",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "maximized": true,
        "decorations": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://*.supabase.co https://github.com https://objects.githubusercontent.com"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "OmniPlan"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "L&D Energy",
    "category": "Productivity",
    "shortDescription": "professional floor plan software",
    "longDescription": "OmniPlan — offline-first 2D/3D floor-plan drawing and property data tool for estate agents, EPC assessors and interior designers.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Hvssmuh/OmniPlan-Releases/releases/latest/download/latest.json"
      ],
      "pubkey": "RWSWDQ9iHU6N65PIFFGfkcBOEeMaoY0W33dEXnW+OLL/PnitSKeWfRrz",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
